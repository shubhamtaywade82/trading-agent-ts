# Ollama server URL (local tier)
# OLLAMA_HOST=http://localhost:11434

# API key for cloud tier (https://ollama.com)
# OLLAMA_API_KEY=

# Default model tag
# TRADINGAGENT_MODEL=qwen3.5:4b

# Tier: "local" (default) or "cloud"
# TRADINGAGENT_TIER=local

# Workspace root directory (defaults to process.cwd())
# TRADINGAGENT_WORKSPACE=

# Request timeout in milliseconds
# TRADINGAGENT_TIMEOUT_MS=60000

# Custom system prompt (overrides built-in default)
# TRADINGAGENT_SYSTEM_PROMPT=

# Docker image for sandboxed shell execution
# TRADINGAGENT_SHELL_IMAGE=tradingagent-sandbox:latest

# Shell command timeout in seconds
# TRADINGAGENT_SHELL_TIMEOUT_SEC=30

# Paper-trading Telegram notifications (readiness alerts + entry/exit fills).
# Same env var names as the janus repo — one bot/chat works across both.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_API_BASE=https://api.telegram.org

# Paper-trading LLM components (analyst + per-trade evaluator) use Ollama
# CLOUD by default — requires OLLAMA_API_KEY above. Default cloud model:
# gpt-oss:20b. Set TRADINGAGENT_ANALYST_TIER=local to use local Ollama
# instead, which then defaults to minicpm5-1b (pull it first: `ollama pull
# minicpm5-1b`). TRADINGAGENT_ANALYST_MODEL overrides the model either way.
# TRADINGAGENT_ANALYST_TIER=cloud
# TRADINGAGENT_ANALYST_MODEL=gpt-oss:20b
